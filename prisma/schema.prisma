// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id              String     @id @default(cuid())
  name            String     @unique
  alliance        String?    @default("BOM")
  leaderNotes     String     @default("")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  gloryWarStatus  String     @default("Offline")
  kills           Int        @default(0)
  totalPower      Int        @default(0)
  march1Power     Int        @default(0)
  march2Power     Int        @default(0)
  march3Power     Int        @default(0)
  march4Power     Int        @default(0)
  latestScore     Float      @default(0)
  snapshots       Snapshot[]
  duelScores      AllianceDuelScore[]
  account         User?
}

model Snapshot {
  id              String   @id @default(cuid())
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  kills           Int
  totalPower      Int
  structurePower  Int
  techPower       Int
  troopPower      Int
  heroPower       Int
  modVehiclePower Int
  score           Float    @default(0)
}

model Bug {
  id          String   @id @default(cuid())
  reporter    String?  @default("Anonymous")
  description String
  priority    String   @default("Medium")
  status      String   @default("Open")
  createdAt   DateTime @default(now())
}

model User {
  id             String        @id @default(cuid())
  playerId       String        @unique
  player         Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  passwordHash   String
  isActive       Boolean       @default(true)
  disabledByUser Boolean       @default(false)
  mustChangePassword Boolean   @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sessions       UserSession[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

model AllianceApplicant {
  id              String   @id @default(cuid())
  name            String
  timezone        String   @default("")
  status          String   @default("New")
  notes           String   @default("")
  techPower       Int      @default(0)
  heroPower       Int      @default(0)
  troopPower      Int      @default(0)
  modVehiclePower Int      @default(0)
  structurePower  Int      @default(0)
  combatPower     Int      @default(0)
  kills           Int      @default(0)
  manualAdjustment Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MigrationCandidate {
  id              String   @id @default(cuid())
  name            String
  originalServer  String
  originalAlliance String
  reasonForLeaving String  @default("")
  contactStatus   String   @default("Scouted")
  status          String   @default("Scouted")
  notes           String   @default("")
  techPower       Int      @default(0)
  heroPower       Int      @default(0)
  troopPower      Int      @default(0)
  modVehiclePower Int      @default(0)
  structurePower  Int      @default(0)
  combatPower     Int      @default(0)
  kills           Int      @default(0)
  manualAdjustment Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AllianceDuelRequirement {
  id           String   @id @default(cuid())
  dayKey        String   @unique
  eventName     String
  minimumScore  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AllianceDuelScore {
  id         String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  scoreType   String
  dayKey      String   @default("ALL")
  score       Int      @default(0)
  rank        Int?
  source      String   @default("manual")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([playerId, scoreType, dayKey])
  @@index([scoreType, dayKey])
}
