// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id          String     @id @default(cuid())
  name        String     @unique
  alliance    String?    @default("Last Z Base")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  gloryWarStatus String  @default("Offline")
  kills       Int        @default(0)
  totalPower  Int        @default(0)
  latestScore Float      @default(0)
  snapshots   Snapshot[]
}

model Snapshot {
  id              String   @id @default(cuid())
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  kills           Int
  totalPower      Int
  structurePower  Int
  techPower       Int
  troopPower      Int
  heroPower       Int
  modVehiclePower Int
  score           Float    @default(0)
}

model Bug {
  id          String   @id @default(cuid())
  reporter    String?  @default("Anonymous")
  description String
  priority    String   @default("Medium")
  status      String   @default("Open")
  createdAt   DateTime @default(now())
}
